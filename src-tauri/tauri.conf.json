{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogDownloader",
  "version": "0.1.0",
  "identifier": "com.readlog.downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "日志下载器",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
